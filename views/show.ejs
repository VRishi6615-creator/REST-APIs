<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>See in detail</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Here is the details of @<%= post.username %> posts</h1>
    <h4 class="id">post id : <%= post.id %></h4>
     <div class="post">
        <h3 class="user">@ <%= post.username %></h3>
        <h4 class="content"><%= post.content %></h4>
    </div>
</body>
</html>